{
  "manifest_version": 3,
  "name": "Skill Factory",
  "version": "0.0.1",
  "description": "Skill Factory Chrome Extension",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "permissions": ["activeTab"]
}
