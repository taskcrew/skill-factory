{
  "manifest_version": 3,
  "name": "Skill Factory Recorder",
  "version": "1.0.0",
  "description": "Chrome extension recording user behavior for AI agent browsing workflows",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "cookies",
    "accessibilityFeatures.read"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
